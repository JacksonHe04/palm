# HTTP 服务器配置
server {
    listen 80;
    server_name 139.155.248.15 joinpalm.inon.space;

    # 添加安全相关的响应头
    add_header Cross-Origin-Opener-Policy "unsafe-none" always;
    add_header Cross-Origin-Embedder-Policy "unsafe-none" always;

    location /static/ {
        alias /home/ubuntu/palm-ams/back-django/static/;
        add_header Cache-Control "public, max-age=31536000";
        
        types {
            text/css css;
            application/javascript js;
            image/svg+xml svg;
        }
    }

    location / {
        include uwsgi_params;
        uwsgi_pass 127.0.0.1:8001;
    }
}

# HTTPS 服务器配置
server {
    listen 443 ssl;
    server_name palm.inon.space;
    
    ssl_certificate /etc/nginx/palm.inon.space_bundle.crt;
    ssl_certificate_key /etc/nginx/palm.inon.space.key;
    ssl_session_timeout 5m;
    ssl_protocols TLSv1.2;
    ssl_ciphers ECDHE-RSA-AES128-GCM-SHA256:HIGH:!aNULL:!MD5:!RC4:!DHE;
    ssl_prefer_server_ciphers on;

    client_max_body_size 20M;
    client_body_buffer_size 20M;

    # 添加安全相关的响应头
    add_header Cross-Origin-Opener-Policy "unsafe-none" always;
    add_header Cross-Origin-Embedder-Policy "unsafe-none" always;

    location /static/ {
        alias /home/ubuntu/palm-ams/back-django/static/;
        add_header Cache-Control "public, max-age=31536000";
        
        types {
            text/css css;
            application/javascript js;
            image/svg+xml svg;
        }
    }

    location / {
        include uwsgi_params;
        uwsgi_pass 127.0.0.1:8001;
    }
}